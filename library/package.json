{
  "name": "@noaa-gsl/charts",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.0.0",
  "description": "An extension of D3 for visualizing weather data in a variety of charts.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/noaa-gsl-charts.umd.js",
  "module": "./dist/noaa-gsl-charts.es.js",
  "exports": {
    ".": {
      "import": "./dist/noaa-gsl-charts.es.js",
      "require": "./dist/noaa-gsl-charts.umd.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://vlab.noaa.gov/gitlab-community/OAR/GSL/DESI/desi-charts",
  "scripts": {
    "dev": "vite",
    "build:dev": "vite build --config vite.config.dev.js",
    "postbuild:dev": "yalc push",
    "build": "vite build --config vite.config.prod.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "size": "npx vite-bundle-visualizer"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "vite": "^7.2.6"
  },
  "peerDependencies": {
    "d3": "~7.9.0",
    "lodash": "~4.17.21",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
